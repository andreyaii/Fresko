<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_toast.xml
    Rounded background for FreskoToast.
    The fill color is set at runtime via backgroundTintList,
    so this shape just provides the corner radius + a neutral
    fallback color.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Neutral fallback; overridden programmatically -->
    <solid android:color="#0B6646" />

    <corners android:radius="20dp" />

</shape>