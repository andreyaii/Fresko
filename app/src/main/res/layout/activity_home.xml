<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════ HEADER ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_header"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="44dp"
                android:paddingBottom="36dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fresko"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02" />

                <TextView
                    android:id="@+id/tvAttentionSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Everything looks fresh 🎉"
                    android:textColor="#CCF5FFE0"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPillExpiring"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_green"
                        android:backgroundTint="#33FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp"
                        android:text="⚠ 0 expiring today"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPillFresh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_pill_green"
                        android:backgroundTint="#33FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp"
                        android:text="✅ 0 fresh"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- ══════════ EXPIRING SOON SECTION ══════════ -->
            <TextView
                android:id="@+id/tvLabelExpiringSoon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="⚠  NEEDS ATTENTION"
                android:textColor="#BF360C"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFoodList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:visibility="gone" />

            <!-- ── Empty/fresh state (shown when 0 items need attention) ── -->
            <LinearLayout
                android:id="@+id/layoutNoExpiring"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="28dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="36sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="All items are fresh!"
                    android:textColor="#2E7D32"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Nothing needs your attention right now."
                    android:textColor="#9E9E9E"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ── Total empty state (shown only when inventory = 0 items) ── -->
            <LinearLayout
                android:id="@+id/layoutTotallyEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="28dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛒"
                    android:textSize="48sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Your inventory is empty."
                    android:textColor="#1C1C1E"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Time to stock up! Tap ＋ to add your first item."
                    android:textColor="#9E9E9E"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ══════════ STORAGE LOCATIONS ══════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="10dp"
                android:text="STORAGE LOCATIONS"
                android:textColor="#BDBDBD"
                android:letterSpacing="0.1"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Fridge -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFridge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="18dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_pill_green"
                            android:backgroundTint="#E3F2FD"
                            android:text="🥦"
                            android:textSize="26sp"
                            android:gravity="center" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fridge"
                                android:textColor="#212121"
                                android:textSize="17sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvFridgeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 items"
                                android:textColor="#90A4AE"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#BDBDBD"
                            android:textSize="30sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Pantry -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPantry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="18dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_pill_green"
                            android:backgroundTint="#FBE9E7"
                            android:text="🥫"
                            android:textSize="26sp"
                            android:gravity="center" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pantry"
                                android:textColor="#212121"
                                android:textSize="17sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvPantryCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 items"
                                android:textColor="#90A4AE"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#BDBDBD"
                            android:textSize="30sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Freezer -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFreezer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="18dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_pill_green"
                            android:backgroundTint="#E0F7FA"
                            android:text="❄️"
                            android:textSize="26sp"
                            android:gravity="center" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Freezer"
                                android:textColor="#212121"
                                android:textSize="17sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvFreezerCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 items"
                                android:textColor="#90A4AE"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#BDBDBD"
                            android:textSize="30sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddFood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="92dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="#0B6646"
        app:elevation="8dp"
        app:tint="#FFFFFF" />

    <!-- Bottom Nav -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="#0B6646" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#0B6646"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_history"
                app:tint="#BDBDBD" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textColor="#BDBDBD"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>