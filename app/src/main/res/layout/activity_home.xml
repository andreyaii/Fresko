<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background_cream">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_header"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="60dp"
                android:paddingBottom="48dp"
                android:elevation="4dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FOOD EXPIRATION TRACKER"
                        android:textColor="#B3FFFFFF"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Fresko"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAttentionSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Everything looks fresh 🎉"
                        android:textColor="#E1F5EE"
                        android:textSize="15sp"
                         />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnLogout"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:src="@drawable/ic_logout"
                    app:tint="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"/>
            </RelativeLayout>

            <!-- STATS SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                android:weightSum="3">
                
                    <!-- Stat Card: Total Items -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/colorSurface"
                        app:cardElevation="2dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/colorBorder">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="4dp">
                            <TextView
                                android:id="@+id/tvStatTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textColor="@color/colorPrimary"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Items"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:gravity="center"
                                android:maxLines="1"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Stat Card: Expiring Soon -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/colorSurface"
                        app:cardElevation="2dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/colorBorder">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="4dp">
                            <TextView
                                android:id="@+id/tvStatExpiringSoon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textColor="@color/colorExpiryAmber"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Expiring"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:gravity="center"
                                android:maxLines="1"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Stat Card: Expired -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/colorSurface"
                        app:cardElevation="2dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/colorBorder">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="4dp">
                            <TextView
                                android:id="@+id/tvStatExpired"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textColor="@color/colorExpiryRed"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Expired"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:gravity="center"
                                android:maxLines="1"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    
            </LinearLayout>

            <!-- SEARCH BAR -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:strokeWidth="1dp"
                app:strokeColor="@color/colorBorder">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/colorTextSecondary" />
                        
                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@null"
                        android:hint="Search Food Item..."
                        android:textColor="@color/colorTextPrimary"
                        android:textColorHint="@color/colorTextSecondary"
                        android:textSize="15sp"
                        android:singleLine="true"
                        android:imeOptions="actionSearch"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION: EXPIRING SOON -->
            <TextView
                android:id="@+id/tvLabelExpiringSoon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="EXPIRING SOON"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFoodList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                android:visibility="gone" />

            <!-- EMPTY STATES -->
            <LinearLayout
                android:id="@+id/layoutNoExpiring"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/tvNoExpiringText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All your items are fresh! ✨"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="15sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutTotallyEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="40dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your inventory is empty.\nTap + to start."
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- STORAGE LOCATIONS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="16dp"
                android:text="STORAGE LOCATIONS"
                android:textColor="@color/colorTextSecondary"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <!-- Fridge Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFridge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_pill_green"
                                android:backgroundTint="@color/fridge_light"
                                android:padding="12dp"
                                android:src="@drawable/ic_fridge"
                                app:tint="@color/fridge_dark" />
                            <TextView
                                android:id="@+id/tvFridgeCount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="0"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Fridge"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-medium" />
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/pbFridgeFreshness"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:trackThickness="8dp"
                            app:trackCornerRadius="4dp"
                            app:indicatorColor="@color/fridge_dark"
                            app:trackColor="@color/fridge_light"
                            android:max="100" />
                        <TextView
                            android:id="@+id/tvFridgeFreshLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="100% FRESH"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Pantry Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPantry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_pill_green"
                                android:backgroundTint="@color/pantry_light"
                                android:padding="12dp"
                                android:src="@drawable/ic_pantry"
                                app:tint="@color/pantry_dark" />
                            <TextView
                                android:id="@+id/tvPantryCount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="0"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Pantry"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-medium" />
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/pbPantryFreshness"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:trackThickness="8dp"
                            app:trackCornerRadius="4dp"
                            app:indicatorColor="@color/pantry_dark"
                            app:trackColor="@color/pantry_light"
                            android:max="100" />
                        <TextView
                            android:id="@+id/tvPantryFreshLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="100% FRESH"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Freezer Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFreezer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_pill_green"
                                android:backgroundTint="@color/freezer_light"
                                android:padding="12dp"
                                android:src="@drawable/ic_freezer"
                                app:tint="@color/freezer_dark" />
                            <TextView
                                android:id="@+id/tvFreezerCount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="0"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Freezer"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-medium" />
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/pbFreezerFreshness"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:trackThickness="8dp"
                            app:trackCornerRadius="4dp"
                            app:indicatorColor="@color/freezer_dark"
                            app:trackColor="@color/freezer_light"
                            android:max="100" />
                        <TextView
                            android:id="@+id/tvFreezerFreshLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="100% FRESH"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Modern Floating Pill Bottom Nav -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="36dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardElevation="12dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="5"
            android:paddingHorizontal="8dp">

            <LinearLayout
                android:id="@+id/btnNavHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    app:tint="@color/colorPrimaryLight" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textColor="@color/colorPrimaryLight"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnNavInsights"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="@color/colorTextSecondary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Insights"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/btnAddFood"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_add"
                    android:padding="14dp"
                    android:background="@drawable/bg_pill_green"
                    android:backgroundTint="#0B6646"
                    android:backgroundTintMode="src_over"
                    app:tint="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="4dp"
                    android:outlineProvider="background" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/btnNavHistory"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_history"
                    app:tint="@color/colorTextSecondary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="History"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="false"
                android:focusable="false"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_scan"
                    app:tint="@color/colorTextSecondary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>