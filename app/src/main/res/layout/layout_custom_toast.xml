<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_custom_toast.xml
    A custom toast view that shows a tinted icon circle + a message.
    The root LinearLayout background tint is set programmatically by
    FreskoToast.kt so a single layout file covers all CRUD states.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toastRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="220dp"
    android:background="@drawable/bg_toast"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!--
        Icon circle — emoji / text character set by FreskoToast.kt.
        White semi-transparent circle so it contrasts on any bg color.
    -->
    <TextView
        android:id="@+id/tvToastIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_toast_icon_circle"
        android:gravity="center"
        android:text="✓"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Message text -->
    <TextView
        android:id="@+id/tvToastMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Item saved!"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="2" />

</LinearLayout>