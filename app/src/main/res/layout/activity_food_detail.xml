<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F5F7">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#00BFA5"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item Details"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/detailsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:layout_margin="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:id="@+id/tvDetailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#00BFA5"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textColor="#212121"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/tvDetailDaysLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expires in X days"
                android:textColor="#FF9800"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDetailExactDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exact Date: 2026-04-20"
                android:textColor="#757575"
                android:textSize="16sp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/tvDetailLogged"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logged on: 2026-04-15"
                android:textColor="#9E9E9E"
                android:textSize="14sp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="24dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnDetailEdit"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="EDIT ITEM"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00BFA5"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnDetailDelete"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="DELETE ITEM"
            android:textColor="#F44336"
            android:backgroundTint="#FFEBEE"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            style="?android:attr/borderlessButtonStyle"/>
    </LinearLayout>

</RelativeLayout>