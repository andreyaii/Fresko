<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background_cream">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_home_header"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:text="Add New Item"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="Fill in the details below"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_marginTop="-40dp"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_pill_green"
                        android:backgroundTint="#E8F5E9"
                        android:letterSpacing="0.1"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="ITEM DETAILS"
                        android:textColor="#0B6646"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etFoodName"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Food Name (e.g. Milk)"
                        android:inputType="textCapWords"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#212121"
                        android:textColorHint="#ADB5BD"
                        android:textSize="15sp" />

                    <!-- DASHED LINE ADDED HERE -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginVertical="24dp"
                        android:background="@drawable/bg_dashed_line"
                        android:layerType="software" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WHERE DOES IT BELONG?"
                        android:textColor="#9E9E9E"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:id="@+id/categoryGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3"
                        android:layout_marginBottom="24dp">

                        <LinearLayout android:id="@+id/btnCatFridge"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginEnd="4dp"
                            android:background="@drawable/bg_rounded_chip"
                            android:orientation="vertical" android:gravity="center"
                            android:padding="12dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_fridge" app:tint="#FFFFFF"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Fridge" android:textColor="#FFFFFF"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnCatPantry"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginHorizontal="4dp"
                            android:background="@drawable/bg_food_card"
                            android:orientation="vertical" android:gravity="center"
                            android:padding="12dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_pantry" app:tint="#E65100"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Pantry" android:textColor="#757575"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnCatFreezer"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="4dp"
                            android:background="@drawable/bg_food_card"
                            android:orientation="vertical" android:gravity="center"
                            android:padding="12dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_freezer" app:tint="#1976D2"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Freezer" android:textColor="#757575"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- SECOND DASHED LINE (Optional, for that receipt look) -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_dashed_line"
                        android:layerType="software" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectDate"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="+ SELECT EXPIRY DATE"
                        android:textColor="#E65100"
                        android:textStyle="bold"
                        app:backgroundTint="#FFF3E0"
                        app:cornerRadius="12dp" />

                    <TextView
                        android:id="@+id/tvSelectedDateDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="No date selected"
                        android:textColor="#9E9E9E"
                        android:textSize="13sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="24dp"
        android:background="@drawable/bg_white_fade"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveFood"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SAVE ITEM"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#0B6646"
            android:textStyle="bold"
            app:cornerRadius="18dp"
            app:elevation="4dp" />
    </LinearLayout>

</RelativeLayout>