<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.myfresko.SplashFragment"
        android:label="SplashFragment"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.myfresko.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_addFood"
            app:destination="@id/addFoodFragment" />

        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/foodDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/addFoodFragment"
        android:name="com.example.myfresko.AddFoodFragment"
        android:label="Add New Item"
        tools:layout="@layout/fragment_add_food" />

    <fragment
        android:id="@+id/foodDetailFragment"
        android:name="com.example.myfresko.FoodDetailFragment"
        android:label="Food Detail"
        tools:layout="@layout/fragment_food_detail" />

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.myfresko.HistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_history" />

</navigation>